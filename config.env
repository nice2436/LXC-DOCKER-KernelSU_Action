# 内核源码地址
KERNEL_SOURCE=https://github.com/nice2436/kernel_realme_sm8250

# 内核源码分支
# 该仓库默认分支为 master
KERNEL_SOURCE_BRANCH=bigshot-AOSP

# 内核编译配置
# Realme SM8250 平台的配置文件通常位于 arch/arm64/configs/vendor/daylight_defconfig
KERNEL_CONFIG=defconfig

# 内核打包名字，自定义
KERNEL_ZIP_NAME=Realme_GTMEx_LXC-Docker_$(date +%Y%m%d%H%M)

# 是否开启kvm
ENABLE_KVM=false

# 是否开启lxc-docker
ENABLE_LXC_DOCKER=true

# 选择要打包的内核镜像文件
# 骁龙 870/865 (SM8250) 属于高端机型，建议填 Image
# 如果你的刷机包（AnyKernel3）脚本支持压缩格式，也可以填 Image.gz
KERNEL_IMAGE_NAME=Image

# 是否需要LLVM=1 LLVM_IAS=1参数
# 现代内核源码编译（4.19/5.10+）基本都需要，填 y
LLVM_CONFIG=y

# 是否需要切换python2
SWITCH_PYTHON=false

# 是否需要dtbo
# Realme GT 大师探索版在刷入内核时通常需要同步刷入 dtbo.img 以保证显示或快充正常
NEED_DTBO=true

# KernelSU 配置
# 如果你想同时集成 KernelSU，将此处改为 true
ENABLE_KERNELSU=true
KERNELSU_TAG=main
